# Django Security Settings
# Generate a random secret key for production
SECRET_KEY=your-secret-key-here
DEBUG=True
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Server Settings
PORT=8000

# CORS Settings
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=False

# CSRF Settings
# Comma-separated list of trusted origins
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Settings
# Currently using SQLite by default
DATABASE_NAME=db.sqlite3

# Logging
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO

# Security Settings (Only active if DEBUG=False)
SECURE_SSL_REDIRECT=False

# Firebase Service Account JSON (Minified)
FIREBASE_SERVICE_ACCOUNT_JSON='{"your":"json_content_here"}'
