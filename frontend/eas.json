{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WS_URL": "wss://play-veee.onrender.com/ws/stream/",
        "EXPO_PUBLIC_API_URL": "https://play-veee.onrender.com/listen/"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WS_URL": "wss://play-veee.onrender.com/ws/stream/",
        "EXPO_PUBLIC_API_URL": "https://play-veee.onrender.com/listen/"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_WS_URL": "wss://play-veee.onrender.com/ws/stream/",
        "EXPO_PUBLIC_API_URL": "https://play-veee.onrender.com/listen/"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
